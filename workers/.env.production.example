# Connexio AI Production File Delivery System Configuration
# Copy this file to .env and update with your actual values

# Required: Slack Bot Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Optional: Server Configuration
PORT=3000
DOWNLOAD_PORT=3001
STORAGE_DIR=./storage
MAX_FILE_SIZE=52428800
RETENTION_DAYS=30

# Optional: API Keys for Enhanced Features
# SendGrid API Key for real email validation
SENDGRID_API_KEY=your-sendgrid-api-key-here

# Claude API Key for AI-powered deduplication
CLAUDE_API_KEY=your-claude-api-key-here
# Alternative: Anthropic API Key
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Advanced Configuration
NODE_ENV=production
LOG_LEVEL=info
ENABLE_FILE_ENCRYPTION=true
DOWNLOAD_RATE_LIMIT_MAX=10
GENERAL_RATE_LIMIT_MAX=100

# Optional: CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# Optional: Security Configuration
REQUIRE_AUTH=true
LOG_DOWNLOADS=true

# Example Slack App Setup Instructions:
# 1. Create a new Slack app at https://api.slack.com/apps
# 2. Enable Socket Mode and generate tokens
# 3. Add OAuth Scopes: app_mentions:read, channels:history, chat:write, files:read, commands
# 4. Install app to workspace and copy tokens above
# 5. Configure slash commands: /connexio, /validate-file, /help