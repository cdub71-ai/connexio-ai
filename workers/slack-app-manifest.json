{
  "display_information": {
    "name": "Connexio AI",
    "description": "Enterprise AI marketing automation platform with advanced data operations and campaign optimization",
    "background_color": "#2c3e50",
    "long_description": "Connexio AI delivers enterprise-grade marketing operations through Slack with data enrichment, deliverability analysis, AI segmentation, campaign auditing, and intelligent optimization powered by Claude AI."
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": false
    },
    "bot_user": {
      "display_name": "Connexio AI",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/connexio",
        "url": "https://connexio-slack-simple.fly.dev/slack/events",
        "description": "Ask Connexio AI marketing questions",
        "usage_hint": "[question] - Get AI-powered marketing advice",
        "should_escape": false
      },
      {
        "command": "/validate-file",
        "url": "https://connexio-slack-simple.fly.dev/slack/events",
        "description": "Upload and validate email/phone data in CSV files",
        "usage_hint": "[description] - Validate file data quality",
        "should_escape": false
      },
      {
        "command": "/enrich-file",
        "url": "https://connexio-slack-simple.fly.dev/slack/events",
        "description": "Enrich CSV files with external data sources",
        "usage_hint": "[description] - Apollo, Clearbit, Hunter enrichment",
        "should_escape": false
      },
      {
        "command": "/deliverability-check",
        "url": "https://connexio-slack-simple.fly.dev/slack/events",
        "description": "Analyze email deliverability and domain reputation",
        "usage_hint": "[email/domain] - DNS, SPF, DKIM analysis",
        "should_escape": false
      },
      {
        "command": "/segment-strategy",
        "url": "https://connexio-slack-simple.fly.dev/slack/events",
        "description": "AI-powered audience segmentation and targeting",
        "usage_hint": "[audience description] - Strategic segmentation",
        "should_escape": false
      },
      {
        "command": "/campaign-audit",
        "url": "https://connexio-slack-simple.fly.dev/slack/events",
        "description": "Comprehensive campaign performance analysis",
        "usage_hint": "[campaign details] - Performance optimization",
        "should_escape": false
      },
      {
        "command": "/create-campaign",
        "url": "https://connexio-slack-simple.fly.dev/slack/events",
        "description": "Create new marketing campaigns",
        "usage_hint": "[campaign details] - Campaign creation",
        "should_escape": false
      },
      {
        "command": "/campaign-status",
        "url": "https://connexio-slack-simple.fly.dev/slack/events",
        "description": "Check campaign status and metrics",
        "usage_hint": "[campaign id] - Status monitoring",
        "should_escape": false
      },
      {
        "command": "/help",
        "url": "https://connexio-slack-simple.fly.dev/slack/events",
        "description": "Show available Connexio AI commands",
        "usage_hint": "Get help with bot commands",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "commands",
        "chat:write",
        "files:read",
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "users:read",
        "app_mentions:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://connexio-slack-simple.fly.dev/slack/events",
      "bot_events": [
        "file_shared",
        "app_mention"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}